    {
      "id": "iYII7W74Oxxv_WvfI1O-g",
      "type": "text",
      "x": 748,
      "y": 1248,
      "width": 351.93975830078125,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
