      "isDeleted": false,
      "boundElements": null,
      "updated": 1766291534803,
      "link": null,
      "locked": false,
      "text": "1. Easier development \n2. Efficient ingestion\n3. Automated Orchestration\n4. Auto Incremental load\n5. Unified Batch and Steraming load\n6. Automated data quality check\n7. Automated Monitering \n8. Serverless Compute\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Easier development \n2. Efficient ingestion\n3. Automated Orchestration\n4. Auto Incremental load\n5. Unified Batch and Steraming load\n6. Automated data quality check\n7. Automated Monitering \n8. Serverless Compute\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
