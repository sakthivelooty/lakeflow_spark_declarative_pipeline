    {
      "id": "U_qoSsiWM3Zt___Ca20KZ",
      "type": "text",
      "x": 646,
      "y": 737,
      "width": 286.6997985839844,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aH",
      "roundness": null,
      "seed": 2130000442,
      "version": 110,
      "versionNonce": 1456657254,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1766259269296,
      "link": null,
      "locked": false,
      "text": "Like standard views, \nmaterialized views are the \nresults of a query and you \naccess them the same way \nyou would a table. Unlike \nstandard views, which \nrecompute results \non every query, materialized\n views cache the results and \nrefreshes them on a \nspecified interval.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Like standard views, \nmaterialized views are the \nresults of a query and you \naccess them the same way \nyou would a table. Unlike \nstandard views, which \nrecompute results \non every query, materialized\n views cache the results and \nrefreshes them on a \nspecified interval.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ZbOzJMjWm6UJYuyfHlmnY",
      "type": "text",
      "x": 1466,
      "y": 782,
      "width": 267.059814453125,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aI",
      "roundness": null,
      "seed": 217723066,
      "version": 107,
      "versionNonce": 1923477286,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1766259281679,
      "link": null,
      "locked": false,
      "text": "Pipelines also provide \nfunctionality to let y\nou write to a wide range \nof sinks, or even\nprogrammatically transform \nand stream data to any \narget (or targets) that \nyou can \nwrite to with Python.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pipelines also provide \nfunctionality to let y\nou write to a wide range \nof sinks, or even\nprogrammatically transform \nand stream data to any \narget (or targets) that \nyou can \nwrite to with Python.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "DCNAbPg0CZRp7B7c3KYJN",
